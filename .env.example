# ═══════════════════════════════════════════════════════════════════════════
# Environment Variables — Sportix Public Demo
# ═══════════════════════════════════════════════════════════════════════════
#
# Copier ce fichier en .env et adapter les valeurs pour votre environnement
#
# ═══════════════════════════════════════════════════════════════════════════

# Backend Configuration
NODE_ENV=development
PORT=3000
JWT_SECRET=sportix-demo-jwt-secret-2024-change-in-production

# Database Configuration
DB_PATH=./src/data/sportix.db

# Frontend Configuration
API_URL=http://localhost:3000
NG_PORT=4200

# Docker Configuration
COMPOSE_PROJECT_NAME=sportix-public
DOCKER_NETWORK=sportix-network

# Mobile/Network Configuration
# Pour Flutter/mobile, utiliser l'IP locale du poste de développement
# Ex: API_MOBILE_URL=http://192.168.1.100:3000

# Development vs Production
DEV_MODE=true
PROD_MODE=false

# ═══════════════════════════════════════════════════════════════════════════
